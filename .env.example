NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-me
NEXT_PUBLIC_FIREBASE_APP_ID=replace-me
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace-me

FIREBASE_PROJECT_ID=replace-me
# Local development only. Cloud Run should use service identity instead.
GOOGLE_APPLICATION_CREDENTIALS=E:\\CAMPUS LOOP\\secrets\\firebase-admin.json
# Vercel or other non-Google runtimes can use one of these instead of GOOGLE_APPLICATION_CREDENTIALS.
# FIREBASE_ADMIN_CREDENTIALS_JSON={"project_id":"replace-me","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# FIREBASE_ADMIN_CREDENTIALS_BASE64=base64-encoded-service-account-json

FIREBASE_DATACONNECT_SERVICE_ID=replace-me
FIREBASE_DATACONNECT_LOCATION=asia-south1
