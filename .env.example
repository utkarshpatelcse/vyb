NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
VYB_API_BASE_URL=http://localhost:4000
VYB_INTERNAL_API_KEY=local-vyb-internal-key
VYB_SESSION_SECRET=replace-with-a-long-random-session-secret
VYB_CORS_ALLOWED_ORIGINS=http://localhost:3000

NEXT_PUBLIC_FIREBASE_API_KEY=replace-me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-me
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-me.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-me
NEXT_PUBLIC_FIREBASE_APP_ID=replace-me
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace-me

FIREBASE_PROJECT_ID=replace-me
# Local development only. Cloud Run should use service identity instead.
GOOGLE_APPLICATION_CREDENTIALS=E:\\CAMPUS LOOP\\secrets\\firebase-admin.json
# Vercel or other non-Google runtimes can use one of these instead of GOOGLE_APPLICATION_CREDENTIALS.
# FIREBASE_ADMIN_CREDENTIALS_JSON={"project_id":"replace-me","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# FIREBASE_ADMIN_CREDENTIALS_BASE64=base64-encoded-service-account-json

FIREBASE_DATACONNECT_SERVICE_ID=replace-me
FIREBASE_DATACONNECT_LOCATION=asia-south1
# Game level stores default to DataConnect when admin credentials are available, otherwise they use bundled local seeds in auto mode.
# Set VYB_QUEENS_LEVELS_SOURCE=dataconnect to require DataConnect and fail fast when it is unavailable.
# Set VYB_QUEENS_LEVELS_SOURCE=local to force the server-only data/queens-levels.json fallback.
# VYB_QUEENS_LEVELS_SOURCE=auto
# Current first-onboarded college reference values for local development.
VYB_DEFAULT_TENANT_SLUG=kiet
VYB_DEFAULT_TENANT_DOMAIN=kiet.edu
