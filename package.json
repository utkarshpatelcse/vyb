{
  "name": "vyb",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --filter=@vyb/web",
    "dev:web": "pnpm --filter @vyb/web dev",
    "dev:backend": "pnpm --filter @vyb/backend dev",
    "dc:services": "node scripts/run-firebase-cli.mjs dataconnect:services:list",
    "dc:compile": "node scripts/run-firebase-cli.mjs dataconnect:compile",
    "dc:sdk": "node scripts/run-firebase-cli.mjs dataconnect:sdk:generate",
    "dc:deploy": "node scripts/run-firebase-cli.mjs deploy --only dataconnect",
    "dc:migrate": "node scripts/run-firebase-cli.mjs dataconnect:sql:migrate --service vyb --location asia-south1 --force",
    "dc:deploy:social": "node scripts/run-firebase-cli.mjs deploy --only dataconnect:vyb:schema,dataconnect:vyb:social",
    "dc:release:social": "pnpm dc:compile && pnpm dc:migrate && pnpm dc:deploy:social",
    "queens:seed": "node scripts/seed-queens-levels-dataconnect.mjs",
    "connect:migrate-local": "node scripts/migrate-connect-local-store-dataconnect.mjs",
    "dc:deploy:other-device": "powershell -ExecutionPolicy Bypass -File scripts/deploy-dataconnect-other-device.ps1",
    "bootstrap:tenant": "node scripts/bootstrap-dataconnect.mjs",
    "chat:janitor": "node scripts/chat-janitor.mjs",
    "chat:reset": "node scripts/chat-reset.mjs",
    "chat:security-validate": "node scripts/validate-chat-security.mjs",
    "build": "turbo run build",
    "check": "turbo run check",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "firebase-tools": "^15.16.0",
    "pnpm": "^10.33.0",
    "turbo": "latest",
    "typescript": "latest"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "3.0.1",
      "postcss": "8.5.13"
    },
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
